{
  "name": "@pagopa/ts-commons",
  "version": "13.1.2",
  "description": "Shared TypeScript code for the IO project",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "repository": "https://github.com/pagopa/io-ts-commons",
  "author": "https://www.pagopa.gov.it",
  "license": "MIT",
  "files": [
    "lib/"
  ],
  "scripts": {
    "build": "tsc",
    "test": "NODE_TLS_REJECT_UNAUTHORIZED=0 jest",
    "lint": "eslint . -c .eslintrc.js --ext .ts,.tsx",
    "check-typings": "tsc -p typings-checker",
    "typedoc": "typedoc --out docs/ --exclude '**/__tests__/*' --theme minimal src",
    "docs": "rimraf docs && npm run typedoc && touch docs/.nojekyll",
    "version": "yarn changeset version && yarn --mode update-lockfile",
    "release": "yarn build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@pagopa/eslint-config": "^3.0.0",
    "@types/express": "4.17.6",
    "@types/jest": "^29.5.1",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^22.19.11",
    "@types/node-fetch": "^2.1.7",
    "@types/semver": "^7.3.10",
    "@types/validator": "^10.11.0",
    "eslint": "^8.12.0",
    "eslint-plugin-prettier": "^4.2.1",
    "fp-ts": "^2.16.5",
    "io-ts": "^2.2.21",
    "jest": "^29.5.0",
    "mock-http-server": "^1.4.4",
    "patch-package": "^6.4.7",
    "prettier": "^2.8.8",
    "rimraf": "^2.6.2",
    "ts-jest": "^29.0.5",
    "typedoc": "0.24.6",
    "typescript": "4.9.5"
  },
  "dependencies": {
    "abort-controller": "^3.0.0",
    "agentkeepalive": "^4.1.4",
    "applicationinsights": "^2.9.5",
    "jose": "^4.15.5",
    "json-set-map": "^1.1.2",
    "jsonwebtoken": "^9.0.1",
    "node-fetch": "^2.6.0",
    "semver": "^7.5.2",
    "ulid": "^2.3.0",
    "validator": "^13.7.0"
  },
  "peerDependencies": {
    "fp-ts": "^2.16.5",
    "io-ts": "^2.2.21"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverage": true,
    "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.(jsx?|tsx?)$",
    "preset": "ts-jest",
    "testMatch": null,
    "transform": {
      "^.+\\.[tj]sx?$": [
        "ts-jest",
        {
          "diagnostics": {
            "ignoreCodes": [
              2502
            ]
          }
        }
      ]
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
